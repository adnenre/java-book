---
// src/components/FileTree.astro
import { parse } from 'node-html-parser';

interface TreeNode {
  label: string;
  href: string;
  children: TreeNode[];
}

export interface Props {
  base?: string; // e.g., 'docs' (without leading/trailing slash)
}

const { base = '' } = Astro.props;

// Detect language from the current URL (assumes /:lang/docs/... pattern)
const pathname = Astro.url.pathname;
const match = pathname.match(/^\/([^/]+)/);
let lang = match ? match[1] : 'en';

// Optional: restrict to supported languages
const supportedLangs = ['en', 'fr'];
if (!supportedLangs.includes(lang)) {
  lang = 'en'; // fallback
}

const rootPath = `/${lang}${base ? '/' + base : ''}`;

const slugify = (text: string): string => {
  // First replace dots with hyphens (for numbering)
  const withHyphens = text.replace(/\./g, '-');
  return withHyphens
    .toLowerCase()
    .replace(/[^\w\s-]/g, '')
    .replace(/\s+/g, '-')
    .replace(/--+/g, '-')
    .replace(/^-|-$/g, '');
}
function buildTree(ul: any, parentPath: string): TreeNode[] {
  const nodes: TreeNode[] = [];
  const items = ul.querySelectorAll(':scope > li');

  for (const li of items) {
    const textNodes = li.childNodes.filter((n: any) => n.nodeType === 3);
    const label = textNodes.map((n: any) => n.textContent).join('').trim();
    if (!label) continue;

    const slug = slugify(label);
    const href = parentPath ? `${parentPath}/${slug}` : `/${slug}`;
    const node: TreeNode = { label, href, children: [] };

    const nestedUl = li.querySelector('ul');
    if (nestedUl) {
      node.children = buildTree(nestedUl, href);
    }

    nodes.push(node);
  }

  return nodes;
}

function renderNode(node: TreeNode, depth = 0): string {
  const paddingLeft = depth * 24;

  // Top‑level directory → collapsible, no link
  if (depth === 0 && node.children.length > 0) {
    const childrenHtml = node.children
      .map((child) => renderNode(child, depth + 1))
      .join('');

    return `
      <li class="directory">
        <details>
          <summary style="padding-left:${paddingLeft}px">
            ${node.label}
          </summary>
          <ul class="tree-children">
            ${childrenHtml}
          </ul>
        </details>
      </li>
    `;
  }

  // File → link
  return `
    <li class="file">
      <a href="${node.href}" 
         class="file-link" 
         style="padding-left:${paddingLeft}px">
        ${node.label}
      </a>
    </li>
  `;
}

const html = await Astro.slots.render('default');
const root = parse(html);
const firstUl = root.querySelector('ul');
const tree = firstUl ? buildTree(firstUl, rootPath) : [];
const treeHtml = tree.map((node) => renderNode(node)).join('');
---

{
  tree.length > 0 ? (
    <div class="file-tree not-content">
      <style>
        /* (same styles as before) */
        .file-tree {
          border: 1px solid var(--sl-color-gray-5);
          border-radius: 0.5rem;
          padding: 1rem;
          background-color: var(--sl-color-gray-7);
          font-family: var(--__sl-font-mono);
          font-size: 0.9rem;
        }
        .file-tree ul {
          margin: 0;
          padding: 0;
          list-style: none;
        }
        .file-tree li {
          margin: 0.125rem 0;
        }
        .directory > details {
          border: 0;
          padding: 0;
          background: transparent;
        }
        .directory > details > summary {
          cursor: pointer;
          padding: 0.25rem 0.5rem;
          border-radius: 0.25rem;
        }
        .directory > details > summary:hover {
          background-color: var(--sl-color-gray-6);
        }
        .file-link {
          display: block;
          padding: 0.25rem 0.5rem;
          border-radius: 0.25rem;
          text-decoration: none;
          color: var(--sl-color-text);
        }
        .file-link:hover {
          background-color: var(--sl-color-gray-6);
          color: var(--sl-color-text-accent);
        }
        .tree-children {
          margin-left: 1rem;
          border-left: 1px solid var(--sl-color-gray-5);
          padding-left: 0.5rem;
        }
      </style>

      <ul set:html={treeHtml} />
    </div>
  ) : (
    <p>(empty file tree)</p>
  )
}